---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { ui, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const frUrl = new URL("/", Astro.site);
const enUrl = new URL("/en/", Astro.site);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Club Code",
  url: Astro.site?.href,
  logo: new URL("/img/logo.svg", Astro.site).href,
  description: t.meta.description,
  sameAs: ["https://github.clubcode.fr", "https://discord.clubcode.fr"],
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: "Télécom SudParis",
    url: "https://www.telecom-sudparis.eu",
  },
});
---

<!doctype html>
<html lang={lang} transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <link rel="icon" type="image/svg+xml" href="/img/mark.svg" />
    <link rel="apple-touch-icon" href="/img/icon-180.png" />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === "fr" ? "fr_FR" : "en_US"} />
    <meta
      property="og:locale:alternate"
      content={lang === "fr" ? "en_US" : "fr_FR"}
    />
    <meta property="og:site_name" content="Club Code" />
    <meta property="og:image" content={new URL("/img/og.png", Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    <meta name="twitter:image" content={new URL("/img/og.png", Astro.site)} />
    <meta name="theme-color" content="#08080d" />
    <script type="application/ld+json" set:html={jsonLd} />
    <ClientRouter />
    {
      [
        "clash-display-500",
        "clash-display-600",
        "satoshi-400",
        "satoshi-500",
        "satoshi-700",
      ].map((f) => (
        <link
          rel="preload"
          href={`/fonts/${f}.woff2`}
          as="font"
          type="font/woff2"
          crossorigin
        />
      ))
    }
  </head>
  <body>
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <div class="grain" aria-hidden="true"></div>

    <script>
      import type { TransitionBeforeSwapEvent } from "astro:transitions/client";

      const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

      let io: IntersectionObserver | undefined;
      let cio: IntersectionObserver | undefined;

      let ghosts: { el: HTMLElement; section: HTMLElement }[] = [];
      let ghostTick = false;
      const drift = () => {
        ghostTick = false;
        for (const g of ghosts) {
          const r = g.section.getBoundingClientRect();
          const d = r.top + r.height / 2 - innerHeight / 2;
          g.el.style.transform = `translateY(${(d * 0.12).toFixed(1)}px)`;
        }
      };
      addEventListener(
        "scroll",
        () => {
          if (ghosts.length && !ghostTick) {
            ghostTick = true;
            requestAnimationFrame(drift);
          }
        },
        { passive: true },
      );

      // Cloudflare's email obfuscation is only decoded by its injected
      // script on a full page load; after a ClientRouter swap the encoded
      // placeholders ("[email protected]") survive, so decode them ourselves.
      const decodeCfEmail = (hex: string) => {
        const key = parseInt(hex.slice(0, 2), 16);
        let out = "";
        for (let i = 2; i < hex.length; i += 2)
          out += String.fromCharCode(parseInt(hex.slice(i, i + 2), 16) ^ key);
        return out;
      };
      const decodeEmails = () => {
        document
          .querySelectorAll<HTMLElement>("[data-cfemail]")
          .forEach((el) => el.replaceWith(decodeCfEmail(el.dataset.cfemail!)));
        document
          .querySelectorAll<HTMLAnchorElement>(
            'a[href*="/cdn-cgi/l/email-protection#"]',
          )
          .forEach((a) => {
            a.href = "mailto:" + decodeCfEmail(a.href.split("#")[1]);
          });
      };

      const init = () => {
        decodeEmails();
        io?.disconnect();
        io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io!.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.1 },
        );
        document
          .querySelectorAll<HTMLElement>(".reveal:not(.is-visible)")
          .forEach((el) => io!.observe(el));

        document
          .querySelectorAll<HTMLElement>("[data-stagger]")
          .forEach((parent) => {
            [...parent.children].forEach((child, i) => {
              (child as HTMLElement).style.setProperty(
                "--reveal-delay",
                `${i * 0.12}s`,
              );
            });
          });

        ghosts = [];
        for (const id of [
          "club",
          "competitions",
          "services",
          "infrastructure",
          "partenaires",
          "contact",
        ]) {
          const section = document.getElementById(id);
          const num = section
            ?.querySelector(".section-label")
            ?.textContent?.match(/\d+/)?.[0];
          if (!section || !num) continue;
          const el = document.createElement("span");
          el.className = "ghost-num";
          el.textContent = num;
          el.setAttribute("aria-hidden", "true");
          section.prepend(el);
          ghosts.push({ el, section });
        }
        if (ghosts.length && !reduced) drift();

        cio?.disconnect();
        const counters = document.querySelectorAll<HTMLElement>(
          "[data-count]:not([data-counted])",
        );
        if (!reduced && counters.length) {
          cio = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (!entry.isIntersecting) continue;
                cio!.unobserve(entry.target);
                entry.target.setAttribute("data-counted", "");
                const node = entry.target.firstChild;
                if (!(node instanceof Text)) continue;
                const m = (node.data ?? "").match(/\d+/);
                if (!m) continue;
                const end = parseInt(m[0], 10);
                const suffix = node.data.slice((m.index ?? 0) + m[0].length);
                const from = Math.max(0, end - Math.min(end, 60));
                const t0 = performance.now();
                const D = 1300;
                const step = (now: number) => {
                  const u = Math.min((now - t0) / D, 1);
                  const eased = 1 - Math.pow(1 - u, 3);
                  node.data = Math.round(from + (end - from) * eased) + suffix;
                  if (u < 1) requestAnimationFrame(step);
                };
                requestAnimationFrame(step);
              }
            },
            { threshold: 0.6 },
          );
          counters.forEach((el) => cio!.observe(el));
        }
      };

      document.addEventListener("astro:page-load", init);

      let langSwitch = false;
      let savedScroll = 0;
      let anchorId: string | null = null;
      let anchorDelta = 0;

      document.addEventListener("astro:before-swap", (e) => {
        const ev = e as TransitionBeforeSwapEvent;
        langSwitch = !!ev.sourceElement?.closest("[data-lang-switch]");
        if (!langSwitch) return;

        anchorId = null;
        for (const section of document.querySelectorAll("main section[id]")) {
          const top = section.getBoundingClientRect().top;
          if (top <= 0) {
            anchorId = section.id;
            anchorDelta = -top;
          }
        }

        const reveals = ev.newDocument.querySelectorAll(".reveal");
        document.querySelectorAll(".reveal").forEach((el, i) => {
          if (el.classList.contains("is-visible"))
            reveals[i]?.classList.add("is-visible");
        });
        const counters = ev.newDocument.querySelectorAll("[data-count]");
        document.querySelectorAll("[data-count]").forEach((el, i) => {
          if (el.hasAttribute("data-counted"))
            counters[i]?.setAttribute("data-counted", "");
        });
      });

      const restoreScroll = () => {
        let top = savedScroll;
        const el = anchorId && document.getElementById(anchorId);
        if (el) top = el.getBoundingClientRect().top + scrollY + anchorDelta;
        scrollTo({ top, behavior: "instant" });
      };

      document.addEventListener("astro:after-swap", () => {
        if (langSwitch) restoreScroll();
      });
      document.addEventListener("astro:page-load", () => {
        if (!langSwitch) return;
        langSwitch = false;
        restoreScroll();
      });
    </script>
  </body>
</html>
