---
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].about;
---

<section class="section" id="club">
  <div class="container">
    <div class="section-head">
      <p class="section-label reveal">{t.label}</p>
      <h2 class="section-title reveal" style="--reveal-delay: 0.08s">{t.title}</h2>
      <p class="section-intro reveal" style="--reveal-delay: 0.16s">{t.intro}</p>
    </div>

    <div class="pillars" data-stagger>
      {
        t.pillars.map((p, i) => (
          <article class="panel reveal">
            <div class="panel-inner pillar">
              <span class="pillar-index">{String(i + 1).padStart(2, '0')}</span>
              <h3>{p.name}</h3>
              <p>{p.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .pillar {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .pillar-index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--lav-soft);
    letter-spacing: 0.18em;
  }

  .pillar h3 {
    font-size: 1.35rem;
  }

  .pillar p {
    color: var(--ink-soft);
    font-size: 0.98rem;
  }

  @media (max-width: 860px) {
    .pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
