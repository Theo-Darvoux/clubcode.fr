---
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].about;
---

<section class="section" id="club">
  <div class="section-bg" aria-hidden="true">
    <span class="x" style="top: 16%; left: 6%"></span>
    <span class="x" style="top: 66%; left: 11.5%"></span>
    <span class="x" style="bottom: 11%; right: 7%"></span>
  </div>
  <div class="container">
    <div class="section-head">
      <p class="section-label reveal">{t.label}</p>
      <h2 class="section-title reveal" style="--reveal-delay: 0.08s">{t.title}</h2>
      <p class="section-intro reveal" style="--reveal-delay: 0.16s">{t.intro}</p>
    </div>

    <div class="pillars" data-stagger>
      {
        t.pillars.map((p, i) => (
          <article class="panel reveal">
            <div class="panel-inner pillar">
              <span class="pillar-index">{String(i + 1).padStart(2, '0')}</span>
              <h3>{p.name}</h3>
              <p>{p.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    overflow: hidden;
  }

  .section-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(90deg, rgba(220, 183, 255, 0.07) 0 1px, transparent 1px 88px);
    mask-image: radial-gradient(ellipse 62% 78% at 14% 38%, black 25%, transparent 78%);
    -webkit-mask-image: radial-gradient(ellipse 62% 78% at 14% 38%, black 25%, transparent 78%);
  }

  .section-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 42% 52% at 16% 32%, rgba(220, 183, 255, 0.06), transparent 70%);
  }

  .x {
    position: absolute;
    width: 17px;
    height: 17px;
    background:
      linear-gradient(rgba(220, 183, 255, 0.34), rgba(220, 183, 255, 0.34)) center / 1px 100% no-repeat,
      linear-gradient(rgba(220, 183, 255, 0.34), rgba(220, 183, 255, 0.34)) center / 100% 1px no-repeat;
  }

  @media (max-width: 860px) {
    .x {
      display: none;
    }
  }

  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .pillar {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .pillar-index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--lav-soft);
    letter-spacing: 0.18em;
  }

  .pillar h3 {
    font-size: 1.35rem;
  }

  .pillar p {
    color: var(--ink-soft);
    font-size: 0.98rem;
  }

  @media (max-width: 860px) {
    .pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
