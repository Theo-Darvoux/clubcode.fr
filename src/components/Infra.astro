---
import { ui, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].infra;
---

<section class="section" id="infrastructure">
  <div class="section-bg" aria-hidden="true">
    <svg
      class="traces"
      viewBox="0 0 560 360"
      fill="none"
      preserveAspectRatio="xMinYMax meet"
    >
      <path d="M0 312 H148 L196 264 H332"></path>
      <path d="M0 240 H96 L144 192 H236 L268 160 H352"></path>
      <path d="M40 360 V296 L88 248 V184"></path>
      <circle cx="332" cy="264" r="3.5"></circle>
      <circle cx="352" cy="160" r="3.5"></circle>
      <circle cx="88" cy="184" r="3.5"></circle>
      <circle cx="236" cy="192" r="2.5"></circle>
    </svg>
  </div>
  <div class="container">
    <div class="head-row">
      <div class="section-head">
        <p class="section-label reveal">{t.label}</p>
        <h2 class="section-title reveal" style="--reveal-delay: 0.08s">
          {t.title}
        </h2>
        <p class="section-intro reveal" style="--reveal-delay: 0.16s">
          {t.intro}
        </p>
      </div>
    </div>

    <div class="items" data-stagger>
      {
        t.items.map((item, i) => (
          <article class="item reveal">
            <span class="item-index">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h3>{item.name}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    overflow: hidden;
  }

  .section-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 8% 14%,
        rgba(220, 183, 255, 0.05),
        transparent 50%
      ),
      radial-gradient(rgba(220, 183, 255, 0.07) 1.5px, transparent 1.5px) 0 0 /
        24px 24px;
    mask-image:
      linear-gradient(
        to bottom,
        transparent,
        black 15%,
        black 85%,
        transparent
      ),
      radial-gradient(ellipse 70% 80% at 12% 32%, black 30%, transparent 80%);
    -webkit-mask-image:
      linear-gradient(
        to bottom,
        transparent,
        black 15%,
        black 85%,
        transparent
      ),
      radial-gradient(ellipse 70% 80% at 12% 32%, black 30%, transparent 80%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .traces {
    position: absolute;
    left: 0;
    bottom: 0;
    width: clamp(280px, 32vw, 560px);
    height: auto;
    mask-image: linear-gradient(120deg, black 55%, transparent 95%);
    -webkit-mask-image: linear-gradient(120deg, black 55%, transparent 95%);
  }

  .traces path {
    stroke: rgba(220, 183, 255, 0.12);
    stroke-width: 1;
  }

  .traces circle {
    fill: rgba(220, 183, 255, 0.28);
  }

  .head-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }


  .items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--line-soft);
  }

  .item {
    display: flex;
    gap: 1.4rem;
    padding: 2rem 1.5rem 2rem 0;
    border-bottom: 1px solid var(--line-soft);
    transition: background 0.35s var(--ease-out);
  }

  .item:hover {
    background: linear-gradient(90deg, var(--lav-08), transparent 75%);
  }

  .item:nth-child(odd) {
    border-right: 1px solid var(--line-soft);
    padding-left: 0;
    padding-right: 2rem;
  }

  .item:nth-child(even) {
    padding-left: 2rem;
  }

  .item-index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--lav-soft);
    letter-spacing: 0.15em;
    padding-top: 0.35rem;
  }

  .item h3 {
    font-size: 1.18rem;
    margin-bottom: 0.5rem;
  }

  .item p {
    color: var(--ink-soft);
    font-size: 0.96rem;
  }

  @media (max-width: 860px) {
    .head-row {
      flex-direction: column;
    }


    .items {
      grid-template-columns: 1fr;
    }

    .item:nth-child(odd) {
      border-right: none;
      padding-right: 0;
    }

    .item:nth-child(even) {
      padding-left: 0;
    }
  }
</style>
